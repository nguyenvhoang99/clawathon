# Local development only — do NOT include GREENNODE_* vars in deploy .env
# (AgentBase Runtime auto-injects GREENNODE_CLIENT_ID, GREENNODE_CLIENT_SECRET,
#  GREENNODE_AGENT_IDENTITY, GREENNODE_ENDPOINT_URL)

# GreenNode AI Platform LLM (use /agentbase-llm to create an API key)
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=
