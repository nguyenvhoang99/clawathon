# Local development only — do NOT include GREENNODE_* vars in deploy .env
# (AgentBase Runtime auto-injects GREENNODE_CLIENT_ID, GREENNODE_CLIENT_SECRET,
#  GREENNODE_AGENT_IDENTITY, GREENNODE_ENDPOINT_URL)
#
# Root .env is optional for local dev. Each agent uses its own agents/<name>/.env:
#   trip-planner   → LLM_MODEL=gemini/gemini-3.1-pro-preview
#   bill-splitter  → LLM_MODEL=deepseek/deepseek-v4-pro
#   weather-chatbot → LLM_MODEL=google/gemma-4-31b-it
# All agents share the same LLM_API_KEY and LLM_BASE_URL.

# GreenNode AI Platform LLM (use /agentbase-llm to create an API key)
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=gemini/gemini-3.1-pro-preview
